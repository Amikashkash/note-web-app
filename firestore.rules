rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // קריאת מערך השיתוף בצורה בטוחה.
    // מסמכים שנוצרו לפני שהשדה נוסף לא מכילים אותו, וגישה ישירה
    // אליהם הייתה מכשילה את כל הביטוי ולא רק את התנאי הזה.
    function sharedUsers(data) {
      return data.get('sharedWith', []);
    }

    function isSharedWithMe(data) {
      return isAuthenticated() && request.auth.uid in sharedUsers(data);
    }

    // האם העדכון משאיר את שדות הבעלות ללא שינוי.
    // משתמש ששותפו איתו רשאי לערוך תוכן בלבד - לא להשתלט על הפריט
    // ולא לשנות עם מי הוא משותף.
    function ownershipUnchanged() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.get('sharedWith', []) == sharedUsers(resource.data);
    }

    match /categories/{categoryId} {
      allow read: if isOwner(resource.data.userId) || isSharedWithMe(resource.data);

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isOwner(resource.data.userId)
        || (isSharedWithMe(resource.data) && ownershipUnchanged());

      allow delete: if isOwner(resource.data.userId);
    }

    match /notes/{noteId} {
      allow read: if isOwner(resource.data.userId) || isSharedWithMe(resource.data);

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isOwner(resource.data.userId)
        || (isSharedWithMe(resource.data) && ownershipUnchanged());

      allow delete: if isOwner(resource.data.userId);
    }

    match /userSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // מסמך המשתמש המלא - כולל הגדרות אישיות. נגיש לבעליו בלבד.
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // מזהי המכשירים לקבלת התראות push.
      // נדרש match מפורש: כללים ב-Firestore לא חלים על קולקציות משנה
      // אלא אם נעשה שימוש ב-`{document=**}`, ולכן ההרשאה שלמעלה
      // לא מכסה את הקולקציה הזו.
      //
      // הפונקציה המתוזמנת קוראת וכותבת כאן דרך Admin SDK, שעוקף
      // את הכללים - אין צורך להתיר לה גישה במפורש.
      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }
    }

    // אינדקס מינימלי לחיפוש משתמש לפי אימייל, לצורך שיתוף.
    // מכיל רק אימייל ושם תצוגה - בלי הגדרות או מידע אישי אחר.
    //
    // הערה: כל משתמש מחובר יכול לקרוא כאן, וזה מאפשר בדיקה אם אימייל
    // מסוים רשום למערכת. זה המחיר של חיפוש לפי אימייל ישירות מהלקוח.
    // כדי לסגור גם את זה צריך להעביר את החיפוש ל-Cloud Function
    // ולחסום קריאה ישירה לקולקציה.
    match /userLookup/{userId} {
      allow read: if isAuthenticated();

      allow write: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['email', 'displayName'])
        && request.resource.data.email is string;
    }
  }
}
